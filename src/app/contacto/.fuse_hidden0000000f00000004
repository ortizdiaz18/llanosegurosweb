"use client";

import { useState } from "react";
import Link from "next/link";
import { Phone, Mail, Clock, MapPin, MessageSquare, CheckCircle2 } from "lucide-react";
import { Button } from "@/components/ui/button";
import { Input } from "@/components/ui/input";
import { Label } from "@/components/ui/label";
import Navbar from "@/components/Navbar";
import Footer from "@/components/Footer";
import { WordHighlight } from "@/components/motion";
import { Eyebrow } from "@/components/site/Eyebrow";
import { waUrl } from "@/lib/whatsapp";

const contactMethods = [
  {
    icon: Phone,
    title: "Línea nacional",
    value: "01 8000 123 456",
    desc: "Lun–Vie 7:00 am – 7:00 pm",
    action: "tel:018000123456",
    actionLabel: "Llamar",
  },
  {
    icon: MessageSquare,
    title: "WhatsApp",
    value: "+57 310 622 4956",
    desc: "Respuesta en menos de 10 min",
    action: waUrl(),
    actionLabel: "Escribir",
  },
  {
    icon: Mail,
    title: "Correo electrónico",
    value: "hola@llanoseguros.com",
    desc: "Respuesta en menos de 24 horas",
    action: "mailto:hola@llanoseguros.com",
    actionLabel: "Enviar email",
  },
  {
    icon: Clock,
    title: "Horario de atención",
    value: "Lun–Vie 7am–7pm",
    desc: "Sáb 8am–1pm",
    action: null,
    actionLabel: null,
  },
];

export default function Contacto() {
  const [submitted, setSubmitted] = useState(false);
  const [form, setForm] = useState({ name: "", email: "", phone: "", subject: "", message: "" });

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    const message =
      `Hola, quiero contactarme con Llano Seguros.\n\n` +
      `Nombre: ${form.name}\n` +
      `Correo: ${form.email}\n` +
      (form.phone ? `Teléfono: ${form.phone}\n` : "") +
      (form.subject ? `Asunto: ${form.subject}\n` : "") +
      `\nMensaje: ${form.message}`;
    window.open(waUrl(message), "_blank", "noopener,noreferrer");
    setSubmitted(true);
  };

  return (
    <div className="min-h-screen bg-[#F8FAFC]">
      <Navbar />

      {/* Hero */}
      <section className="bg-white border-b border-[#E6E9ED] py-14">
        <div className="container-wide">
          <div className="max-w-xl">
            <h1 className="font-manrope font-extrabold text-5xl text-[#1F2937] mb-3">
              Contáctanos
            </h1>
            <p className="text-gray-500 font-inter text-lg leading-relaxed">
              Estamos aquí para ayudarte. Elige el canal que más te convenga o completa el formulario.
            </p>
          </div>
        </div>
      </section>

      <section className="section-padding">
        <div className="container-wide">
          <div className="grid grid-cols-1 lg:grid-cols-3 gap-10">
            {/* Contact Methods */}
            <div className="lg:col-span-1 space-y-4">
              <h2 className="font-manrope font-bold text-xl text-[#1F2937] mb-5">Canales de contacto</h2>
              {contactMethods.map(({ icon: Icon, title, value, desc, action, actionLabel }) => (
                <div key={title} className="bg-white border border-[#E6E9ED] rounded-2xl p-5 flex gap-4">
                  <div className="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
                    <Icon className="w-5 h-5 text-[#0057B8]" />
                  </div>
                  <div className="flex-1">
                    <div className="font-manrope font-semibold text-[#1F2937] text-sm mb-0.5">{title}</div>
                    <div className="text-[#0057B8] font-inter font-medium text-sm mb-0.5">{value}</div>
                    <div className="text-gray-400 text-xs font-inter mb-2">{desc}</div>
                    {action && actionLabel && (
                      <a
                        href={action}
                        target={action.startsWith("http") ? "_blank" : undefined}
                        rel="noopener noreferrer"
                        className="text-xs font-inter font-medium text-[#0057B8] hover:underline"
                      >
                        {actionLabel} →
                      </a>
                    )}
                  </div>
                </div>
              ))}

              {/* Office */}
              <div className="bg-white border border-[#E6E9ED] rounded-2xl p-5 flex gap-4">
                <div className="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center shrink-0">
                  <MapPin className="w-5 h-5 text-[#0057B8]" />
                </div>
                <div>
                  <div className="font-manrope font-semibold text-[#1F2937] text-sm mb-0.5">Oficina principal</div>
                  <div className="text-gray-600 font-inter text-sm">Cra. 7 # 72-41, Of. 502</div>
                  <div className="text-gray-400 text-xs font-inter">Bogotá, Colombia</div>
                </div>
              </div>

              {/* Map placeholder */}
              <div className="bg-blue-50 border border-blue-100 rounded-2xl h-40 flex items-center justify-center">
                <div className="text-center">
                  <MapPin className="w-8 h-8 text-[#0057B8] mx-auto mb-2" />
                  <p className="text-[#0057B8] text-sm font-inter font-medium">Ver en Google Maps</p>
                </div>
              </div>
            </div>

            {/* Contact Form */}
            <div className="lg:col-span-2">
              <div className="bg-white border border-[#E6E9ED] rounded-2xl p-7 md:p-9">
                {submitted ? (
                  <div className="text-center py-12">
                    <div className="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-5">
                      <CheckCircle2 className="w-8 h-8 text-[#10B981]" />
                    </div>
                    <h2 className="font-manrope font-extrabold text-2xl text-[#1F2937] mb-2">
                      ¡Te redirigimos a WhatsApp!
                    </h2>
                    <p className="text-gray-500 font-inter">
                      Abrimos WhatsApp con tu mensaje listo para enviar. Si no se abrió automáticamente,{" "}
                      <a
                        href={waUrl()}
                        target="_blank"
                        rel="noopener noreferrer"
                        className="text-[#0057B8] font-medium hover:underline"
                      >
                        haz clic aquí
                      </a>
                      .
                    </p>
                  </div>
                ) : (
                  <>
                    <h2 className="font-manrope font-bold text-2xl text-[#1F2937] mb-2">Envíanos un mensaje</h2>
                    <p className="text-gray-500 font-inter text-sm mb-7">Te responderemos por WhatsApp lo antes posible.</p>
                    <form onSubmit={handleSubmit} className="space-y-5">
                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                          <Label className="font-inter text-sm text-gray-700 font-medium mb-1.5 block">
                            Nombre completo *
                          </Label>
                          <Input
                            required
                            className="rounded-xl border-[#E6E9ED] h-11 font-inter"
                            placeholder="Tu nombre"
                            value={form.name}
                            onChange={(e) => setForm({ ...form, name: e.target.value })}
                          />
                        </div>
                        <div>
                          <Label className="font-inter text-sm text-gray-700 font-medium mb-1.5 block">
                            Correo electrónico *
                          </Label>
                          <Input
                            required
                            type="email"
                            className="rounded-xl border-[#E6E9ED] h-11 font-inter"
                            placeholder="tu@correo.com"
                            value={form.email}
                            onChange={(e) => setForm({ ...form, email: e.target.value })}
                          />
                        </div>
                      </div>
                      <div className="grid grid-cols-1 sm:grid-cols-2 gap-5">
                        <div>
                          <Label className="font-inter text-sm text-gray-700 font-medium mb-1.5 block">
                            Teléfono
                          </Label>
                          <Input
                            type="tel"
                            className="rounded-xl border-[#E6E9ED] h-11 font-inter"
                            placeholder="+57 300 000 0000"
                            value={form.phone}
                            onChange={(e) => setForm({ ...form, phone: e.target.value })}
                          />
                        </div>
                        <div>
                          <Label className="font-inter text-sm text-gray-700 font-medium mb-1.5 block">
                            Asunto
                          </Label>
                          <Input
                            className="rounded-xl border-[#E6E9ED] h-11 font-inter"
                            placeholder="¿En qué podemos ayudarte?"
                            value={form.subject}
                            onChange={(e) => setForm({ ...form, subject: e.target.value })}
                          />
                        </div>
                      </div>
                      <div>
                        <Label className="font-inter text-sm text-gray-700 font-medium mb-1.5 block">
                          Mensaje *
                        </Label>
                        <textarea
                          required
                          rows={5}
                          className="w-full rounded-xl border border-[#E6E9ED] px-3 py-3 text-sm font-inter text-gray-700 placeholder:text-gray-400 resize-none focus:outline-none focus:ring-2 focus:ring-[#0057B8]/20 focus:border-[#0057B8]"
                          placeholder="Cuéntanos cómo podemos ayudarte..."
                          value={form.message}
                          onChange={(e) => setForm({ ...form, message: e.target.value })}
                        />
                      </div>
                      <Button
                        type="submit"
                        className="w-full bg-[#0057B8] hover:bg-[#004a9e] text-white rounded-xl h-12 text-base font-inter font-medium"
                      >
                        <MessageSquare className="mr-2 w-4 h-4" /> Enviar por WhatsApp
                      </Button>
                      <p className="text-xs text-gray-400 font-inter text-center">
                        Al enviar aceptas nuestra{" "}
                        <Link href="/privacidad" className="text-[#0057B8] hover:underline">Política de Privacidad</Link>.
                      </p>
                    </form>
                  </>
                )}
              </div>
            </div>
          </div>
        </div>
      </section>

      <Footer />
    </div>
  );
}
