/* ─── Scroll-triggered section wrapper ───────────── */
function ScrollReveal({
  children,
  className = "",
  variants = fadeUp,
  custom = 0,
  once = true,
}: {
  children: React.ReactNode;
  className?: string;
  variants?: Variants;
  custom?: number;
  once?: boolean;
}) {
  const ref = useRef(null);
  const inView = useInView(ref, { once, margin: "-80px 0px" });
  return (
    <motion.div
      ref={ref}
      className={className}
      variants={variants}
      initial="hidden"
      animate={inView ? "visible" : "hidden"}
      custom={custom}
    >
      {children}
    </motion.div>
  );
}

