# Número de WhatsApp para todos los CTA (formato internacional sin +)
NEXT_PUBLIC_WHATSAPP_NUMBER=573106224956

# Feature flag: mostrar botón "Ingresar" / login (sin auth aún -> false)
NEXT_PUBLIC_ENABLE_LOGIN=false

# Feature flag: cotizador online (/cotizar). Aún no disponible -> false
NEXT_PUBLIC_ENABLE_QUOTER=false

# ── Panel de administración (Auth.js) ──
ADMIN_EMAIL=admin@llanoseguros.com
# Hash bcrypt de la contraseña (genera con: node -e "console.log(require('bcryptjs').hashSync('TU_PASS',10))")
ADMIN_PASSWORD_HASH=
# Secreto de sesión (genera con: openssl rand -base64 32)
AUTH_SECRET=
